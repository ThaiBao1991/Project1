{
"update_url": "https://clients2.google.com/service/update2/crx",

  "name": "mycustomFaveTT - download all TikToks you've loved",
  "version": "1.12.63",
  "description": "A tiktok downloader to export all your Likes, Favorites, and Follows to MP4s for safekeeping.",
  "manifest_version": 3,
  "action": {
    "default_title": "mycustomFaveTT",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "b.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*"
      ],
      "js": [
        "c.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.tiktok.com/*"
      ],
      "resources": [
        "rl.html",
        "s.js",
        "ui_offline/*"
      ]
    }
  ],
  "icons": {
    "256": "icon-256.png"
  },
  "permissions": [
    "webRequest",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://*.tiktok.com/api/post/item_list/"
  ]
}